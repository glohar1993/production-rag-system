# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME="Production RAG System"
ENV=development

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_documents

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
SEMANTIC_CACHE_TTL=3600
SEMANTIC_CACHE_THRESHOLD=0.92
CONVERSATION_WINDOW=10

# ── LLM ───────────────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.0

# ── Embeddings ────────────────────────────────────────────────────────────────
DENSE_EMBED_MODEL=BAAI/bge-base-en-v1.5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K_DENSE=20
TOP_K_SPARSE=20
TOP_K_RERANK=5
RRF_K=60

# ── CRAG ──────────────────────────────────────────────────────────────────────
CRAG_RELEVANCE_THRESHOLD=0.6
CRAG_MAX_WEB_RESULTS=3

# ── Security ──────────────────────────────────────────────────────────────────
MAX_QUERY_LENGTH=2000
PII_REDACTION=true

# ── Observability ─────────────────────────────────────────────────────────────
OPIK_API_KEY=
OPIK_PROJECT=production-rag
